    "prepare": "husky install || true",
    "db:migrate": "ts-node lib/migrations.ts migrate",
    "db:rollback": "ts-node lib/migrations.ts rollback",
    "db:status": "ts-node lib/migrations.ts status",
    "postinstall": "patch-package"
  },
